# Rybaspotting configuration
# Copy to .env and fill in your values

# PostgreSQL connection
DATABASE_URL=postgres://user:pass@localhost:5432/rybaspotting?sslmode=disable

# JWT secret for signing tokens (generate with: openssl rand -hex 32)
JWT_SECRET=change-me-to-a-random-secret

# Admin token for admin API endpoints (generate with: openssl rand -hex 32)
ADMIN_TOKEN=change-me-to-another-random-secret

# Listen address (use 127.0.0.1:8080 behind nginx, or 0.0.0.0:8080 for direct)
LISTEN_ADDR=127.0.0.1:8080

# Photo storage directory (used as fallback when R2 is not configured)
PHOTO_DIR=/var/lib/rybaspotting/photos

# ── Cloudflare R2 (S3-compatible) photo storage ────────────────────────
# If all R2_* vars are set, photos are stored in R2 instead of local disk.
# Leave empty to keep using local disk storage.
#
# How to get these values in Cloudflare Dashboard:
#   1. Go to R2 → Create bucket (e.g. "rybaspotting-photos")
#   2. Go to R2 → Manage R2 API Tokens → Create API Token
#      - Permission: "Object Read & Write"
#      - Select your bucket
#   3. Copy the "Access Key ID" and "Secret Access Key"
#   4. Your endpoint is: https://<accountid>.r2.cloudflarestorage.com
#      (found in the R2 dashboard → Account details → Account ID)
#   5. For public URL: set up a custom domain in R2 bucket settings
#      (e.g. cdn.ryby.dom3k.pl) or use the default:
#      https://pub-<hash>.r2.dev
#
# Example:
# R2_ENDPOINT=https://abc123.r2.cloudflarestorage.com
# R2_ACCESS_KEY_ID=abc123...
# R2_SECRET_ACCESS_KEY=xyz789...
# R2_BUCKET=rybaspotting-photos
# R2_PUBLIC_URL=https://cdn.ryby.dom3k.pl

R2_ENDPOINT=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_PUBLIC_URL=

# Allow users to upload photos from gallery (vs only live camera capture)
# Set to true to enable gallery upload, false to disable
ALLOW_GALLERY_UPLOAD=false

# Radius in meters for "nearby fish" query (when checking if a fish exists nearby)
NEARBY_RADIUS_METERS=50

# Maximum photo width in pixels (photos are downscaled to this width)
MAX_PHOTO_WIDTH=1200

# Comma-separated list of accepted captcha answers (Ryby z czym?)
CAPTCHA_ANSWERS=dupom,dupą,dupa
