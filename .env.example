# Rybaspotting configuration
# Copy to .env and fill in your values

# PostgreSQL connection
DATABASE_URL=postgres://user:pass@localhost:5432/rybaspotting?sslmode=disable

# JWT secret for signing tokens (generate with: openssl rand -hex 32)
JWT_SECRET=change-me-to-a-random-secret

# Admin token for admin API endpoints (generate with: openssl rand -hex 32)
ADMIN_TOKEN=change-me-to-another-random-secret

# Listen address (use 127.0.0.1:8080 behind nginx, or 0.0.0.0:8080 for direct)
LISTEN_ADDR=127.0.0.1:8080

# Photo storage directory
PHOTO_DIR=/var/lib/rybaspotting/photos

# Allow users to upload photos from gallery (vs only live camera capture)
# Set to true to enable gallery upload, false to disable
ALLOW_GALLERY_UPLOAD=false

# Radius in meters for "nearby fish" query (when checking if a fish exists nearby)
NEARBY_RADIUS_METERS=30

# Maximum photo width in pixels (photos are downscaled to this width)
MAX_PHOTO_WIDTH=1200
