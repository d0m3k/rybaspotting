# Rybaspotting — DEVELOPMENT environment (use with docker compose)
# Copy to .env if you want to use these values outside Docker (e.g., for scripts)

DATABASE_URL=postgres://rybaspotting:rybaspotting@localhost:5432/rybaspotting?sslmode=disable
JWT_SECRET=dev-secret-change-me-in-prod
LISTEN_ADDR=127.0.0.1:8080
PHOTO_DIR=./dev-photos
ALLOW_GALLERY_UPLOAD=true
NEARBY_RADIUS_METERS=30
MAX_PHOTO_WIDTH=1200
